    {
      "parameters": {
        "jsCode": "const messages = $input.first().json.messages || [];\n\nreturn messages.map(msg => {\n  const text = msg.text || '';\n  \n  if (!msg.bot_id || !text.includes('Partner with MeetGeek')) {\n    return null;\n  }\n  \n  const data = {\n    slack_ts: msg.ts,\n    thread_ts: msg.thread_ts || msg.ts,\n    reply_count: msg.reply_count || 0,\n    interest_type: '',\n    request_details: '',\n    full_name: '',\n    email: '',\n    phone: '',\n    audience_size: '',\n    licenses_considered: '',\n    additional_notes: '',\n    processed_at: new Date().toISOString()\n  };\n  \n  const interestMatch = text.match(/\\*What are you interested in\\?\\*\\n([^*]+?)(?=\\s*\\*Can you)/);\n  if (interestMatch) data.interest_type = interestMatch[1].trim();\n  \n  const requestMatch = text.match(/\\*Can you please tell us more about your request\\?\\*\\n([^*]+?)(?=\\s*\\*What's your full name)/);\n  if (requestMatch) data.request_details = requestMatch[1].trim();\n  \n  const nameMatch = text.match(/\\*What's your full name\\?\\*\\n([^*]+?)(?=\\s*\\*What's your email)/);\n  if (nameMatch) data.full_name = nameMatch[1].trim();\n  \n  const emailMatch = text.match(/\\*What's your email\\?\\*\\n<?(?:mailto:)?([^|>\\s]+)/);\n  if (emailMatch) data.email = emailMatch[1].trim();\n  \n  const phoneMatch = text.match(/\\*What's the best phone number[^*]*\\?\\*\\n([^*]+?)(?=\\s*\\*How large)/);\n  if (phoneMatch) data.phone = phoneMatch[1].trim();\n  \n  const audienceMatch = text.match(/\\*How large is your audience\\?\\*\\n([^*]+?)(?=\\s*\\*How many licenses)/);\n  if (audienceMatch) data.audience_size = audienceMatch[1].trim();\n  \n  const licensesMatch = text.match(/\\*How many licenses are you considering\\?\\*\\n([^*]+?)(?=\\s*(?:\\*|View))/);\n  if (licensesMatch) data.licenses_considered = licensesMatch[1].trim();\n  \n  const extraMatch = text.match(/\\*Anything else you'd like to share\\?\\s*\\*\\n([^*]+?)(?=\\s*View results)/);\n  if (extraMatch) data.additional_notes = extraMatch[1].trim();\n  \n  return { json: data };\n}).filter(item => item !== null && item.json.email);"
      },
